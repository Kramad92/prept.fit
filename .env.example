# Database
DATABASE_URL="postgresql://user:password@localhost:5432/prept"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Prept <noreply@prept.fit>"  # Use resend.dev for testing, your domain for prod

# S3 / R2 Storage (for progress photos)
S3_BUCKET_NAME=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="" # Leave empty for AWS S3, set for Cloudflare R2

# AI (for meal/workout plan generation and food macro lookup)
AI_PROVIDER="groq"             # "groq", "gemini", or "claude"
AI_API_KEY=""                  # Primary provider API key
AI_FALLBACK_PROVIDER="gemini"  # Optional fallback provider
AI_FALLBACK_API_KEY=""         # Fallback provider API key
