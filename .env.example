# Site URL (used for SEO metadata, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL="https://trainer-hub-psi.vercel.app"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/trainerhub"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="TrainerHub <onboarding@resend.dev>"  # Use resend.dev for testing, your domain for prod

# S3 / R2 Storage (for progress photos)
S3_BUCKET_NAME=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="" # Leave empty for AWS S3, set for Cloudflare R2
