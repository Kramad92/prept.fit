{
  "expo": {
    "name": "Prept",
    "slug": "prept",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prept",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10b981"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prept.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Prept needs camera access to take progress photos.",
        "NSPhotoLibraryUsageDescription": "Prept needs photo library access to upload progress photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#10b981"
      },
      "package": "com.prept.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "prept"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Prept needs photo library access to upload progress photos.",
          "cameraPermission": "Prept needs camera access to take progress photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#059669"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.99425826925-4fc798mhna2me66gv6mq4fa1e75bnap3"
        }
      ],
      "expo-apple-authentication",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "c38d25b4-d890-4257-a2fa-f0009aea4ad2"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "kramad92",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c38d25b4-d890-4257-a2fa-f0009aea4ad2"
    }
  }
}
