{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@analytics-core": ["../src/lib/analytics/core/index"],
      "@analytics-core/*": ["../src/lib/analytics/core/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "../src/lib/analytics/core/**/*"
  ]
}
