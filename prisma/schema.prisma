generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multi-tenant: each coach is a tenant
model Tenant {
  id          String   @id @default(cuid())
  name        String   // Business name
  slug        String   @unique // URL slug (subdomain)
  logo        String?  // Logo URL
  brandColor  String   @default("#124559")
  timezone    String   @default("Europe/Sarajevo")
  locale      String   @default("en") // "en", "bs", "sr", or "hr"
  units       String   @default("metric") // "metric" or "imperial"
  currency    String   @default("BAM")
  bio         String?
  phone       String?
  email       String?
  website     String?
  coachPhoto  String?  // Personal headshot (separate from logo)
  socialLinks Json?    // { instagram?, facebook?, tiktok?, youtube?, twitter?, linkedin? }
  specialties Json?    // string[] e.g. ["Weight Loss", "HIIT"]
  landingPageEnabled Boolean @default(false)
  isActive       Boolean  @default(true)
  deactivatedAt  DateTime?
  planTier       String   @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  clients        Client[]
  workouts       WorkoutPlan[]
  schedules      Schedule[]
  availability   Availability[]
  messages       Message[]
  checkInTemplates CheckInTemplate[]
  habitTemplates HabitTemplate[]
  notifications  Notification[]
  mealPlans      MealPlan[]
  exerciseLibrary    ExerciseLibrary[]
  foodLibrary        FoodLibrary[]
  certificates       Certificate[]
  packages           Package[]
  inquiries          Inquiry[]
  equipmentTypes     EquipmentType[]
  exerciseCategories ExerciseCategory[]
  trainingGroups     TrainingGroup[]
  groupSessions      GroupSession[]
  workoutPrograms    WorkoutProgram[]
  nutritionPrograms  NutritionProgram[]
  pushTokens         PushToken[]
  aiUsageLogs        AiUsageLog[]
  storageUsageLogs   StorageUsageLog[]
  platformSubscription PlatformSubscription?

  @@map("tenants")
}

enum UserRole {
  COACH
  CLIENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  role          UserRole  @default(CLIENT)
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // If role is CLIENT, linked client profile
  clientProfile Client?

  sentMessages       Message[] @relation("sender")
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  pushTokens         PushToken[]
  verificationTokens EmailVerificationToken[]

  @@index([tenantId])
  @@map("users")
}

model Client {
  id               String   @id @default(cuid())
  name             String
  email            String?
  phone            String?
  dateOfBirth      DateTime?
  gender           String?
  notes            String?
  goals            String?
  allergies        String?  // e.g. "gluten, dairy, nuts"
  dietaryPrefs     String?  // e.g. "no pork, vegetarian, halal"
  injuries         String?  // e.g. "lower back pain, knee injury"
  fitnessLevel     String?  // "beginner", "intermediate", "advanced"
  activityLevel    String?  // "sedentary", "light", "moderate", "active", "very_active"
  status           String   @default("active") // active, paused, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Optional link to user account (for client portal access)
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  progressPhotos ProgressPhoto[]
  schedules      Schedule[]
  assignedPlans  ClientWorkoutPlan[]
  measurements   Measurement[]
  messages       Message[]
  checkIns       CheckIn[]
  habits         ClientHabit[]
  workoutLogs    WorkoutLog[]
  assignedMealPlans ClientMealPlan[]
  nutritionLogs  NutritionLog[]
  clientExercises ClientExercise[]
  clientMeals     ClientMeal[]
  payments        Payment[]
  inviteTokens    InviteToken[]
  trainingGroupMemberships TrainingGroupMember[]
  groupSessionParticipations GroupSessionParticipant[]
  assignedPrograms  ClientWorkoutProgram[]
  assignedNutritionPrograms ClientNutritionProgram[]

  @@index([tenantId])
  @@map("clients")
}

model Measurement {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  weight    Float?   // in kg or lbs based on tenant preference
  bodyFat   Float?
  chest     Float?
  waist     Float?
  hips      Float?
  arms      Float?
  thighs    Float?
  notes     String?

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("measurements")
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  takenAt   DateTime @default(now())
  category  String?  // front, back, side, custom
  createdAt DateTime @default(now())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("progress_photos")
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  isTemplate  Boolean  @default(false) // Reusable template
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sourceTemplateId String?
  sourceTemplate   WorkoutPlan?  @relation("templateClones", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  clones           WorkoutPlan[] @relation("templateClones")

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  exercises   Exercise[]
  assignedTo  ClientWorkoutPlan[]
  workoutLogs WorkoutLog[]
  groupSessions GroupSession[]
  programDays   WorkoutProgramDay[]

  @@index([tenantId])
  @@index([sourceTemplateId])
  @@map("workout_plans")
}

model Exercise {
  id            String  @id @default(cuid())
  name          String
  sets          Int?
  reps          String? // "12" or "8-12" or "AMRAP"
  weight        String? // "135lbs" or "bodyweight"
  restSeconds   Int?
  notes         String?
  orderIndex    Int     @default(0)
  superset      String? // Group ID for supersets
  videoUrl      String? // YouTube or video URL for form demo

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  logEntries    WorkoutLogEntry[]

  @@index([workoutPlanId])
  @@map("exercises")
}

model ClientWorkoutPlan {
  id          String    @id @default(cuid())
  customName  String?
  notes       String?
  mode        String    @default("solo") // "solo" (client does alone) or "live" (with coach)
  startDate   DateTime?
  endDate     DateTime?
  pausedAt    DateTime? // When the plan was paused (null = not paused)
  isActive    Boolean   @default(true)
  allowDownload Boolean @default(true)
  accessPolicy String  @default("unlimited") // "unlimited", "date_range", "subscription_tied"
  assignedAt  DateTime  @default(now())

  clientId    String
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  clientWorkoutProgramId String?
  clientWorkoutProgram   ClientWorkoutProgram? @relation(fields: [clientWorkoutProgramId], references: [id], onDelete: SetNull)

  clientExercises ClientExercise[]
  groupSessionParticipant GroupSessionParticipant?

  @@index([clientId])
  @@index([workoutPlanId])
  @@index([clientWorkoutProgramId])
  @@map("client_workout_plans")
}

// Coach availability — recurring weekly slots clients can book
model Availability {
  id          String  @id @default(cuid())
  dayOfWeek   Int     // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime   String  // "09:00"
  endTime     String  // "17:00"
  slotMinutes Int     @default(60) // Duration of each bookable slot
  isActive    Boolean @default(true)

  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("availability")
}

model Schedule {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  startTime String   // "09:00"
  endTime   String   // "10:00"
  status    String   @default("scheduled") // scheduled, completed, cancelled, no-show
  notes     String?
  type      String   @default("session") // session, assessment, consultation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([date])
  @@map("schedules")
}

// ========== INVITE TOKENS ==========

model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([clientId])
  @@map("invite_tokens")
}

// ========== EMAIL VERIFICATION ==========

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

// ========== IN-APP MESSAGING ==========

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)

  attachmentUrl  String?
  attachmentType String?  // "image" | "file"
  attachmentName String?

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  senderId  String
  sender    User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([tenantId])
  @@map("messages")
}

// ========== CHECK-INS ==========

model CheckInTemplate {
  id        String   @id @default(cuid())
  name      String   // "Weekly Check-In"
  questions Json     // [{ id, question, type: "text"|"rating"|"number" }]
  frequency String   @default("weekly") // weekly, biweekly, monthly
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  checkIns  CheckIn[]

  @@index([tenantId])
  @@map("check_in_templates")
}

model CheckIn {
  id          String   @id @default(cuid())
  answers     Json     // [{ questionId, answer }]
  submittedAt DateTime @default(now())
  coachNotes  String?  // Coach can respond

  templateId  String
  template    CheckInTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([templateId])
  @@map("check_ins")
}

// ========== HABIT TRACKING ==========

model HabitTemplate {
  id        String   @id @default(cuid())
  name      String   // "Drink 2L Water"
  icon      String?  // emoji or icon name
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientHabits ClientHabit[]

  @@index([tenantId])
  @@map("habit_templates")
}

model ClientHabit {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(true)
  assignedAt DateTime @default(now())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  habitId   String
  habit     HabitTemplate @relation(fields: [habitId], references: [id], onDelete: Cascade)

  logs      HabitLog[]

  @@unique([clientId, habitId])
  @@index([clientId])
  @@map("client_habits")
}

model HabitLog {
  id          String   @id @default(cuid())
  date        DateTime // The day this was logged
  completed   Boolean  @default(true)
  notes       String?
  completedAt DateTime @default(now())

  clientHabitId String
  clientHabit   ClientHabit @relation(fields: [clientHabitId], references: [id], onDelete: Cascade)

  @@unique([clientHabitId, date])
  @@index([clientHabitId])
  @@map("habit_logs")
}

// ========== WORKOUT LOGGING ==========

model WorkoutLog {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  notes       String?
  completed   Boolean  @default(false)
  duration    Int?     // minutes

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  entries     WorkoutLogEntry[]

  @@index([clientId])
  @@index([workoutPlanId])
  @@map("workout_logs")
}

model WorkoutLogEntry {
  id            String  @id @default(cuid())
  setNumber     Int
  repsCompleted Int?
  weightUsed    String? // "140lbs"
  notes         String?
  completed     Boolean @default(true)

  workoutLogId  String
  workoutLog    WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  exerciseId    String
  exercise      Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([workoutLogId])
  @@map("workout_log_entries")
}

// ========== NOTIFICATIONS ==========

model Notification {
  id        String   @id @default(cuid())
  type      String   // session_reminder, new_message, check_in_due, workout_assigned, habit_reminder
  title     String
  body      String
  isRead    Boolean  @default(false)
  data      Json?    // Extra payload (link, IDs, etc.)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId])
  @@map("notifications")
}

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique // Expo push token (ExponentPushToken[xxx])
  platform  String   // "ios" | "android"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@map("push_tokens")
}

// ========== NUTRITION & MEAL PLANS ==========

model MealPlan {
  id          String   @id @default(cuid())
  name        String   // "Fat Loss - 1800 cal" or "Bulking - 3000 cal"
  description String?
  isTemplate  Boolean  @default(false)
  targetCalories Int?
  targetProtein  Int?  // grams
  targetCarbs    Int?  // grams
  targetFat      Int?  // grams
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sourceTemplateId String?
  sourceTemplate   MealPlan?  @relation("mealTemplateClones", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  clones           MealPlan[] @relation("mealTemplateClones")

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  meals       Meal[]
  assignedTo  ClientMealPlan[]
  programDays NutritionProgramDay[]

  @@index([tenantId])
  @@index([sourceTemplateId])
  @@map("meal_plans")
}

model Meal {
  id          String  @id @default(cuid())
  name        String  // dish name (e.g. "Greek Yogurt Parfait", "Grilled Chicken Salad")
  description String? // prep instructions or what the dish is
  time        String? // suggested time "07:30"
  foods       Json    // [{ name, portion, calories, protein, carbs, fat }]
  orderIndex  Int     @default(0)

  mealPlanId  String
  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
  @@map("meals")
}

model ClientMealPlan {
  id          String    @id @default(cuid())
  customName  String?
  notes       String?
  isActive    Boolean   @default(true)
  allowDownload Boolean @default(true)
  assignedAt  DateTime  @default(now())

  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  mealPlanId  String
  mealPlan    MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  clientNutritionProgramId String?
  clientNutritionProgram   ClientNutritionProgram? @relation(fields: [clientNutritionProgramId], references: [id], onDelete: SetNull)

  clientMeals ClientMeal[]

  @@index([clientId])
  @@index([mealPlanId])
  @@index([clientNutritionProgramId])
  @@map("client_meal_plans")
}

model NutritionLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  mealName  String   // "Breakfast", "Lunch", etc. or custom
  foods     String   // free text description of what was eaten
  calories  Int?
  protein   Int?     // grams
  carbs     Int?     // grams
  fat       Int?     // grams
  notes     String?
  photoUrl  String?  // optional meal photo
  createdAt DateTime @default(now())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@map("nutrition_logs")
}

// ========== EXERCISE & FOOD LIBRARIES ==========

model ExerciseLibrary {
  id            String   @id @default(cuid())
  name          String   // English name (canonical)
  nameBs        String?  // Bosnian translation
  category      String?  // "Chest", "Back", "Legs", "Shoulders", "Arms", "Core", "Cardio"
  muscleGroup   String?
  equipment     String?  // "Barbell", "Dumbbell", "Cable", "Bodyweight", etc.
  videoUrl      String?
  instructions  String?

  // Extended fields from exercise database
  difficulty         String?  // "Beginner", "Novice", "Intermediate", "Advanced", "Expert"
  bodyRegion         String?  // "Upper Body", "Lower Body", "Core"
  secondaryMuscles   String?  // Comma-separated secondary + tertiary muscles
  secondaryEquipment String?  // Secondary equipment needed
  movementPattern    String?  // Primary movement pattern (e.g. "Horizontal Push", "Hip Hinge")
  forceType          String?  // "Push", "Pull", "Other"
  mechanics          String?  // "Compound", "Isolation"
  laterality         String?  // "Bilateral", "Unilateral", "Contralateral"
  classification     String?  // "Bodybuilding", "Calisthenics", "Postural", "Olympic Lifting", etc.

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientExercises ClientExercise[]

  @@index([tenantId])
  @@map("exercise_library")
}

model FoodLibrary {
  id              String   @id @default(cuid())
  name            String
  defaultPortion  String?
  calories        Int?
  protein         Int?
  carbs           Int?
  fat             Int?
  category        String?  // "Protein", "Carb", "Fat", "Vegetable", "Fruit", "Dairy", etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientMeals     ClientMeal[]

  @@index([tenantId])
  @@map("food_library")
}

model EquipmentType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("equipment_types")
}

model ExerciseCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("exercise_categories")
}

model ClientExercise {
  id            String   @id @default(cuid())
  name          String
  sets          Int?
  reps          String?
  weight        String?
  restSeconds   Int?
  notes         String?
  videoUrl      String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())

  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  exerciseLibraryId String?
  exerciseLibrary   ExerciseLibrary? @relation(fields: [exerciseLibraryId], references: [id], onDelete: SetNull)

  clientWorkoutPlanId String?
  clientWorkoutPlan   ClientWorkoutPlan? @relation(fields: [clientWorkoutPlanId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientWorkoutPlanId])
  @@map("client_exercises")
}

model ClientMeal {
  id          String   @id @default(cuid())
  name        String   // dish name
  description String?  // prep instructions or what the dish is
  time        String?
  foods       Json     // [{ name, portion, calories, protein, carbs, fat }]
  orderIndex  Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  foodLibraryId String?
  foodLibrary   FoodLibrary? @relation(fields: [foodLibraryId], references: [id], onDelete: SetNull)

  clientMealPlanId String?
  clientMealPlan   ClientMealPlan? @relation(fields: [clientMealPlanId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientMealPlanId])
  @@map("client_meals")
}

// ========== PAYMENT TRACKING ==========

model Payment {
  id          String   @id @default(cuid())
  amount      Float    // Payment amount
  currency    String   @default("USD")
  date        DateTime @default(now()) // When payment was made
  dueDate     DateTime? // When payment was due (for tracking overdue)
  method      String?  // "cash", "bank_transfer", "card", "venmo", "zelle", "other"
  status      String   @default("paid") // "paid", "pending", "overdue", "cancelled"
  period      String?  // What period this covers, e.g. "March 2026", "Q1 2026"
  description String?  // "Monthly coaching fee", "10-session package", etc.
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, status])
  @@index([dueDate])
  @@map("payments")
}

// ========== CERTIFICATES (Coach credentials) ==========

model Certificate {
  id          String   @id @default(cuid())
  name        String
  issuer      String?
  year        Int?
  description String?
  imageUrl    String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("certificates")
}

// ========== PACKAGES (Pricing plans for landing page) ==========

model Package {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  currency    String   @default("USD")
  duration    String?  // "monthly", "one-time", "12 sessions", etc.
  features    Json?    // string[]
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("packages")
}

// ========== INQUIRIES (Contact form submissions) ==========

model Inquiry {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  message       String
  preferredSlot String?
  status        String   @default("new") // "new", "contacted", "archived"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("inquiries")
}

// ========== GROUP TRAINING ==========

model TrainingGroup {
  id               String   @id @default(cuid())
  name             String
  description      String?
  maxParticipants  Int      @default(20)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  members          TrainingGroupMember[]
  sessions         GroupSession[]

  @@index([tenantId])
  @@map("training_groups")
}

model TrainingGroupMember {
  id        String   @id @default(cuid())
  joinedAt  DateTime @default(now())

  groupId   String
  group     TrainingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([groupId, clientId])
  @@index([groupId])
  @@index([clientId])
  @@map("training_group_members")
}

model GroupSession {
  id              String   @id @default(cuid())
  title           String
  date            DateTime
  startTime       String   // "09:00"
  endTime         String   // "10:00"
  location        String?
  notes           String?
  status          String   @default("scheduled") // scheduled, completed, cancelled
  maxParticipants Int      @default(20)
  isOpen          Boolean  @default(false) // any client can join
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  groupId         String?
  group           TrainingGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  workoutPlanId   String?
  workoutPlan     WorkoutPlan? @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)

  participants    GroupSessionParticipant[]

  @@index([tenantId])
  @@index([groupId])
  @@index([date])
  @@map("group_sessions")
}

model GroupSessionParticipant {
  id          String   @id @default(cuid())
  status      String   @default("enrolled") // enrolled, attended, no-show, cancelled
  enrolledAt  DateTime @default(now())

  sessionId   String
  session     GroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  clientId    String
  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  clientWorkoutPlanId String? @unique
  clientWorkoutPlan   ClientWorkoutPlan? @relation(fields: [clientWorkoutPlanId], references: [id], onDelete: SetNull)

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([clientId])
  @@map("group_session_participants")
}

// ========== WORKOUT PROGRAMS ==========

model WorkoutProgram {
  id              String   @id @default(cuid())
  name            String
  description     String?
  durationWeeks   Int      @default(4)
  daysPerWeek     Int      @default(3)
  isTemplate      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceTemplateId String?
  sourceTemplate   WorkoutProgram? @relation("programTemplateClones", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  clones           WorkoutProgram[] @relation("programTemplateClones")

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  days        WorkoutProgramDay[]
  assignments ClientWorkoutProgram[]

  @@index([tenantId])
  @@index([sourceTemplateId])
  @@map("workout_programs")
}

model WorkoutProgramDay {
  id          String  @id @default(cuid())
  weekNumber  Int     // 1-based
  dayNumber   Int     // 1-based within week
  label       String? // "Push Day", "Rest Day", etc.

  programId   String
  program     WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  workoutPlanId String?
  workoutPlan   WorkoutPlan? @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)

  @@index([programId])
  @@map("workout_program_days")
}

model ClientWorkoutProgram {
  id              String   @id @default(cuid())
  startDate       DateTime
  endDate         DateTime?
  accessPolicy    String   @default("date_range") // "unlimited", "date_range", "subscription_tied"
  isActive        Boolean  @default(true)
  currentWeek     Int      @default(1)
  currentDay      Int      @default(1)
  notes           String?
  assignedAt      DateTime @default(now())

  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  programId String
  program   WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  clientWorkoutPlans ClientWorkoutPlan[]

  @@index([clientId])
  @@index([programId])
  @@map("client_workout_programs")
}

// ========== NUTRITION PROGRAMS ==========

model NutritionProgram {
  id              String   @id @default(cuid())
  name            String
  description     String?
  durationWeeks   Int      @default(4)
  mealsPerDay     Int      @default(3)
  isTemplate      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceTemplateId String?
  sourceTemplate   NutritionProgram? @relation("nutritionProgramClones", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  clones           NutritionProgram[] @relation("nutritionProgramClones")

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  days        NutritionProgramDay[]
  assignments ClientNutritionProgram[]

  @@index([tenantId])
  @@index([sourceTemplateId])
  @@map("nutrition_programs")
}

model NutritionProgramDay {
  id          String  @id @default(cuid())
  weekNumber  Int     // 1-based
  dayNumber   Int     // 1-based within week
  label       String? // "High Carb Day", "Rest Day", etc.

  programId   String
  program     NutritionProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  mealPlanId  String?
  mealPlan    MealPlan? @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)

  @@index([programId])
  @@map("nutrition_program_days")
}

model ClientNutritionProgram {
  id              String   @id @default(cuid())
  startDate       DateTime
  endDate         DateTime?
  accessPolicy    String   @default("date_range")
  isActive        Boolean  @default(true)
  currentWeek     Int      @default(1)
  currentDay      Int      @default(1)
  notes           String?
  assignedAt      DateTime @default(now())

  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  programId String
  program   NutritionProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  clientMealPlans ClientMealPlan[]

  @@index([clientId])
  @@index([programId])
  @@map("client_nutrition_programs")
}

// ========== USAGE TRACKING ==========

model AiUsageLog {
  id        String   @id @default(cuid())
  endpoint  String   // e.g. "generate-workout-plan", "generate-meal-plan"
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  provider  String   @default("unknown") // "groq", "gemini", "claude"
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model StorageUsageLog {
  id        String   @id @default(cuid())
  fileKey   String
  sizeBytes Int
  folder    String   @default("uploads")
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
  @@map("storage_usage_logs")
}

model PlatformSubscription {
  id           String   @id @default(cuid())
  status       String   @default("active") // "active", "past_due", "cancelled", "trialing"
  planTier     String   @default("free")
  priceMonthly Float    @default(0)
  currency     String   @default("USD")
  periodStart  DateTime @default(now())
  periodEnd    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("platform_subscriptions")
}

// ========== MOBILE AUTH ==========

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}
